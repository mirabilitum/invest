# DeepSeek API (for LLM features, optional)
DEEPSEEK_API_KEY=sk-your-key-here

# Tushare token (for A-share PE data fallback, optional — primary source is akshare)
TUSHARE_TOKEN=your-tushare-token

# WeChat notification (optional, via ClawBot/OpenClaw webhook)
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# Email notification (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
NOTIFY_EMAIL=recipient@example.com
